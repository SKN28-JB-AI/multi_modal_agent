# ===== 보안 (필수) =====
# 프론트엔드가 X-App-Key 헤더로 보내야 하는 키. 콤마로 여러 개 등록 가능.
APP_KEYS=dev-key-change-me

# 운영에서는 프론트 도메인으로 제한 권장 (콤마 구분)
CORS_ORIGINS=*

# ===== auth-server(OAuth 2.1) JWT 인증 (X-App-Key 와 병행) =====
# 아래 AUTH_ISSUER 를 설정하면 Bearer JWT 자체검증이 켜진다(X-App-Key 도 계속 허용).
# 비워두면 JWT 검증은 꺼지고 X-App-Key 만 사용한다.
# iss(토큰 발급자, 외부 URL). 토큰의 iss 와 정확히 일치해야 함.
# AUTH_ISSUER=http://localhost:9000
# JWKS 공개키 URL. 비우면 AUTH_ISSUER + /jwks.json. 같은 도커 네트워크에선
# 내부 호스트로 지정 가능(예: http://auth-server:9000/jwks.json).
# JWKS_URL=http://auth-server:9000/jwks.json
# 보호 API 호출에 필요한 스코프(비우면 스코프 검증 생략). 시드 스코프: openid/profile/api.
AUTH_REQUIRED_SCOPE=api
# 선택: aud(대상) 검증. 비우면 생략. 예: 특정 client_id.
# AUTH_AUDIENCE=
# exp/nbf 시계 오차 허용(초)
AUTH_LEEWAY_SEC=5

# ===== 외부 API 키 (사용할 백엔드의 키만 설정) =====
OPENAI_API_KEY=          # sora-2 / sora-2-pro + PDF 모드 LLM + TTS 내레이션
GEMINI_API_KEY=          # veo-3.1 / veo-3.1-fast
FAL_API_KEY=             # ltx-2.3 / ltx-2.3-fast (fal.ai)
DASHSCOPE_API_KEY=       # wan-2.2 / wan-2.5 (비디오) + qwen-image (이미지)

# Alibaba Model Studio(DashScope) 리전 엔드포인트. 기본값=International(싱가포르).
# 중국 본토: https://dashscope.aliyuncs.com/api/v1 / 미국: https://dashscope-us.aliyuncs.com/api/v1
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# ===== LLM (PDF 파싱/스토리보드) =====
OPENAI_LLM_MODEL=gpt-4o
# 메시지 모드 비디오 생성 전, OpenAI 기본 모델로 입력 프롬프트를
# 비디오 모델 맞춤형으로 변환할지 여부(기본 true). 요청 본문 enhance_prompt 로 덮어쓰기 가능.
ENHANCE_MESSAGE_PROMPT=true

# 화면 글자 노출 기본 단계: none / minimal / moderate / full (기본 minimal).
# none=모델이 글자 일절 안 그림, minimal=배경 간판 등 환경 텍스트만,
# moderate=짧은 라틴 글자 허용, full=제한 없음. 요청 text_exposure 로 건당 덮어쓰기.
# 또렷한 한글 카피/자막/로고는 모델이 아니라 후처리(자막 번인/오버레이)로 입히길 권장.
TEXT_EXPOSURE_DEFAULT=minimal

# 광고 마지막 로고 엔드카드(아웃트로). 기본 옵션(off) — 요청 logo_outro=true 시 적용.
# 모든 비디오 모델 공통 후처리. 배경색은 요청 시점에 LLM이 추천(키 없으면 아래 색 폴백).
LOGO_OUTRO_ENABLED=false
LOGO_OUTRO_DURATION_SEC=2.5
LOGO_OUTRO_BG_DEFAULT=#134A8E

# 자막 번인 시 사용할 한글 폰트 TTF/TTC 경로(미지정 시 OS 폰트 자동 탐색).
# 글자 깨짐 방지: 비디오 모델은 화면 글자를 못 그리므로, 화면 텍스트는
# negative prompt 로 차단하고 자막은 이 폰트로 '구워서' 표시한다.
# SUBTITLE_FONT_PATH=/usr/share/fonts/truetype/nanum/NanumGothic.ttf
PDF_MAX_PAGES=10

# ===== 비디오 생성 공통 =====
POLL_INTERVAL_SEC=10
POLL_TIMEOUT_SEC=1200
CLIP_RETRIES=1
MAX_CONCURRENT_CLIPS=1

# 모델 ID 가 변경되면 여기서 덮어쓰기 (코드 수정 불필요)
# VEO_MODEL_DEFAULT=veo-3.1-generate-preview
# LTX_ENDPOINT_DEFAULT=fal-ai/ltx-2.3/text-to-video
# WAN_T2V_MODEL_DEFAULT=wan2.2-t2v-plus     # wan-2.2 의 text-to-video 모델 ID
# WAN_I2V_MODEL_DEFAULT=wan2.2-i2v-plus     # wan-2.2 의 image-to-video 모델 ID

# ===== 저장소 =====
DATA_DIR=data

# 브랜드 로고 폴더 (PDF 모드에서 자동 적용. default.png 권장)
LOGOS_DIR=logos

# ===== 로고 오버레이 스타일 =====
LOGO_SCALE_RATIO=0.12     # 로고 폭 = 영상 폭 × 비율 (0.10~0.15 권장)
LOGO_OPACITY=0.82         # 불투명도 (0.7~0.9 권장)
LOGO_POSITION=top-right   # top-right / top-left / bottom-right / bottom-left
LOGO_MARGIN_RATIO=0.03    # 가장자리 여백 비율
LOGO_FADE_IN_SEC=0.6      # 페이드인(초), 0=즉시 표시

# ===== 광고 파