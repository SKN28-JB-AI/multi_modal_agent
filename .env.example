# ===== 보안 (필수) =====
# 프론트엔드가 X-App-Key 헤더로 보내야 하는 키. 콤마로 여러 개 등록 가능.
APP_KEYS=dev-key-change-me

# 운영에서는 프론트 도메인으로 제한 권장 (콤마 구분)
CORS_ORIGINS=*

# ===== 외부 API 키 (사용할 백엔드의 키만 설정) =====
OPENAI_API_KEY=          # sora-2 / sora-2-pro + PDF 모드 LLM + TTS 내레이션
GEMINI_API_KEY=          # veo-3.1 / veo-3.1-fast
FAL_API_KEY=             # ltx-2.3 / ltx-2.3-fast (fal.ai)
DASHSCOPE_API_KEY=       # wan-2.2 / wan-2.5 (비디오) + qwen-image (이미지)

# Alibaba Model Studio(DashScope) 리전 엔드포인트. 기본값=International(싱가포르).
# 중국 본토: https://dashscope.aliyuncs.com/api/v1 / 미국: https://dashscope-us.aliyuncs.com/api/v1
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# ===== LLM (PDF 파싱/스토리보드) =====
OPENAI_LLM_MODEL=gpt-4o
# 메시지 모드 비디오 생성 전, OpenAI 기본 모델로 입력 프롬프트를
# 비디오 모델 맞춤형으로 변환할지 여부(기본 true). 요청 본문 enhance_prompt 로 덮어쓰기 가능.
ENHANCE_MESSAGE_PROMPT=true
PDF_MAX_PAGES=10

# ===== 비디오 생성 공통 =====
POLL_INTERVAL_SEC=10
POLL_TIMEOUT_SEC=1200
CLIP_RETRIES=1
MAX_CONCURRENT_CLIPS=1

# 모델 ID 가 변경되면 여기서 덮어쓰기 (코드 수정 불필요)
# VEO_MODEL_DEFAULT=veo-3.1-generate-preview
# LTX_ENDPOINT_DEFAULT=fal-ai/ltx-2.3/text-to-video
# WAN_T2V_MODEL_DEFAULT=wan2.2-t2v-plus     # wan-2.2 의 text-to-video 모델 ID
# WAN_I2V_MODEL_DEFAULT=wan2.2-i2v-plus     # wan-2.2 의 image-to-video 모델 ID

# ===== 저장소 =====
DATA_DIR=data

# 브랜드 로고 폴더 (PDF 모드에서 자동 적용. default.png 권장)
LOGOS_DIR=logos

# ===== 로고 오버레이 스타일 =====
LOGO_SCALE_RATIO=0.12     # 로고 폭 = 영상 폭 × 비율 (0.10~0.15 권장)
LOGO_OPACITY=0.82         # 불투명도 (0.7~0.9 권장)
LOGO_POSITION=top-right   # top-right / top-left / bottom-right / bottom-left
LOGO_MARGIN_RATIO=0.03    # 가장자리 여백 비율
LOGO_FADE_IN_SEC=0.6      # 페이드인(초), 0=즉시 표시

# ===== 광고 파